{
  "productName": "sentinel-agent",
  "version": "0.1.0",
  "identifier": "com.sentinel.agent",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "./ui-src/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Agent Settings",
        "url": "index.html",
        "width": 1280,
        "height": 700,
        "minWidth": 1280,
        "minHeight": 700,
        "resizable": true,
        "visible": false,
        "center": true,
        "decorations": true,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "fragmentPaths": ["./wix/fragments/run-at-logon.wxs"],
        "componentRefs": ["SentinelRunOnLogon"]
      }
    }
  }
}
